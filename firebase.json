{
  "database": {
    "rules": "database.rules.json"
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "emulators": {
    "auth": {
      "port": 12088
    },
    "firestore": {
      "port": 14701
    },
    "ui": {
      "enabled": true
    },
    "database": {
      "port": 15047
    },
    "functions": {
      "port": 16838
    },
    "hosting": {
      "port": 15951
    }
  },
  "functions": {
    "source": "functions"
  },
  "hosting": {
    "public": "public",
    "rewrites": [
      {
        "source": "**",
        "function": "application"
      }
    ],
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"]
  }
}
